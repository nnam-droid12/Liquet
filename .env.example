# ── QwenCloud ──────────────────────────────────────────────────────────────────
# Get your key at https://dashscope-intl.aliyuncs.com
QWEN_API_KEY=sk-your-key-here
DASHSCOPE_API_KEY=sk-your-dashscope-key-here   # alias used by newer config

# ── Alibaba Cloud ──────────────────────────────────────────────────────────────
ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET_NAME=liquet-evidence
OSS_ENDPOINT=oss-us-east-1.aliyuncs.com
OSS_REGION=us-east-1

# ── Database ───────────────────────────────────────────────────────────────────
# Local SQLite (default)
DATABASE_URL=sqlite+aiosqlite:///./liquet.db

# Alibaba Cloud RDS Postgres (production)
# DATABASE_URL=postgresql+asyncpg://user:pass@rds-host:5432/liquet

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# ── Agent thresholds ──────────────────────────────────────────────────────────
CONF_THRESHOLD=0.80
VALUE_THRESHOLD=500.00

# ── Model selection ────────────────────────────────────────────────────────────
ACTIVE_REASONING_MODEL=qwen-plus
MODEL_VISION=qwen-vl-plus

# ── Cost-saving mode (routes all LLM calls through qwen3.6-plus) ──────────────
CHEAP_MODE=false

# ── MCP server ports ──────────────────────────────────────────────────────────
ORDER_SERVICE_PORT=8001
LOGISTICS_SERVICE_PORT=8002
LISTING_SERVICE_PORT=8003
COMMS_SERVICE_PORT=8004
VISION_INTAKE_PORT=8005
POLICY_ENGINE_PORT=8006
RESOLUTION_SERVICE_PORT=8007

# ── Email intake (Feature: email-driven dispute creation) ──────────────────────
EMAIL_POLLING_ENABLED=false          # set true to activate inbox polling
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=disputes@yourdomain.com
EMAIL_IMAP_PASSWORD=your-gmail-app-password   # Gmail: Settings → App Passwords
EMAIL_POLL_INTERVAL_SECONDS=60

# ── Email sending (SMTP) ───────────────────────────────────────────────────────
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=disputes@yourdomain.com
EMAIL_SMTP_PASSWORD=your-gmail-app-password
EMAIL_FROM=Liquet Disputes <disputes@yourdomain.com>
REVIEWER_EMAIL=reviewer@yourdomain.com   # gets the NON LIQUET approval email

# ── Webhooks (Feature: resolution execution) ───────────────────────────────────
# POST {action, order_id, resolution, amount, rationale} on LIQUET auto-resolve
RESOLUTION_WEBHOOK_URL=https://your-order-system.com/webhooks/liquet-resolution
# POST {action, dispute_id, leaning_verdict, approve_url} on NON LIQUET escalate
ESCALATION_WEBHOOK_URL=https://your-order-system.com/webhooks/liquet-escalation

# ── Human approval (Feature: one-click reviewer approval) ─────────────────────
APPROVAL_SECRET=change-me-to-a-random-secret-32-chars
APP_BASE_URL=http://liquet.43.98.167.71.sslip.io
