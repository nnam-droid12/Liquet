# ── QwenCloud ──────────────────────────────────────────────────────────────────
# Get your key at https://dashscope-intl.aliyuncs.com
QWEN_API_KEY=sk-your-key-here

# ── Alibaba Cloud ──────────────────────────────────────────────────────────────
ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET_NAME=liquet-evidence
OSS_ENDPOINT=oss-us-east-1.aliyuncs.com
OSS_REGION=us-east-1

# ── Database ───────────────────────────────────────────────────────────────────
# Local SQLite (default)
DATABASE_URL=sqlite+aiosqlite:///./liquet.db

# Alibaba Cloud RDS Postgres (production)
# DATABASE_URL=postgresql+asyncpg://user:pass@rds-host:5432/liquet

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# ── Agent thresholds ──────────────────────────────────────────────────────────
CONF_THRESHOLD=0.80
VALUE_THRESHOLD=500.00

# ── Cost-saving mode (routes all LLM calls through qwen3.6-plus) ──────────────
CHEAP_MODE=false

# ── MCP server ports ──────────────────────────────────────────────────────────
ORDER_SERVICE_PORT=8001
LOGISTICS_SERVICE_PORT=8002
LISTING_SERVICE_PORT=8003
COMMS_SERVICE_PORT=8004
VISION_INTAKE_PORT=8005
POLICY_ENGINE_PORT=8006
RESOLUTION_SERVICE_PORT=8007
